# ═══════════════════════════════════════════════
#  RepCheck.one Environment Variables
#  Copy this file to .env.local and fill in values
# ═══════════════════════════════════════════════

# ── Supabase (Phase 6) ──
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ── Stripe (Phase 7) ──
STRIPE_SECRET_KEY=sk_live_your_key_here
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_your_key_here
STRIPE_PRO_PRICE_ID=price_xxxxx
STRIPE_ELITE_PRICE_ID=price_xxxxx

# ── Google AdSense (Phase 4) ──
NEXT_PUBLIC_ADSENSE_ID=ca-pub-YOUR_ID_HERE

# ── Site URL ──
NEXT_PUBLIC_SITE_URL=https://repcheck.one

# ── Solana Token (Phase 8) ──
NEXT_PUBLIC_REPCHK_CONTRACT=your_token_contract_address_here
